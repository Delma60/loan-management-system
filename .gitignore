# Dependencies
/vendor/
/node_modules/
composer.lock

# Local environment overrides (credentials come from real env vars in prod)
/.env
/.env.local

# Editors / OS
/.vscode/
/.idea/
.idea/
/.history/
.DS_Store
Thumbs.db
desktop.ini

# Logs / caches
*.log
*.cache

# User-uploaded loan documents (keep the folder, ignore its contents)
/assets/uploads/*
!/assets/uploads/.gitkeep

# Ad-hoc SQL dumps, but keep the committed schema + seed
*.sql
!/database/schema.sql
!/database/seed.sql
